{
  "name": "@vivliostyle/lcms",
  "description": "Little-CMS WASM bindings for Vivliostyle",
  "version": "0.0.0",
  "author": "Vivliostyle Foundation",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "lib/lcms.js",
  "types": "lib/lcms.d.ts",
  "files": [
    "lib/"
  ],
  "scripts": {
    "devcontainer:up": "devcontainer build --workspace-folder . && node -e \"try{require('child_process').execSync('devcontainer up --workspace-folder .',{timeout:10000,stdio:'inherit'})}catch{}\"",
    "build": "devcontainer exec --workspace-folder . make -C /workspaces/vivliostyle.js/packages/lcms",
    "format": "devcontainer exec --workspace-folder . make -C /workspaces/vivliostyle.js/packages/lcms format",
    "lint": "devcontainer exec --workspace-folder . make -C /workspaces/vivliostyle.js/packages/lcms lint",
    "clean": "shx rm -rf lib/* .obj"
  }
}
